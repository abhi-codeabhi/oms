# Base URL of the control-plane gateway BFF. Default is http://localhost:8080.
# In `vite dev` this also seeds the /api proxy target (see vite.config.ts) so the
# browser stays same-origin and you avoid CORS during local development.
# In a built/static deploy, this is baked in at build time and the app calls it
# directly (the gateway's CORS_ALLOWED_ORIGINS must include the console origin).
VITE_GATEWAY_URL=http://localhost:8080
